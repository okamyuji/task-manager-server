# Task Manager 環境変数テンプレート
# このファイルを .env にコピーして使用してください

# JWT秘密鍵（本番環境では強力なランダム文字列を使用）
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-256-bits

# CORS許可オリジン（カンマ区切りで複数指定可能）
# 開発環境: * で全て許可
# 本番環境: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# ====================
# データベース設定
# ====================

# PostgreSQL接続URL
# 開発環境（Docker Compose）: postgresql://taskmanager:taskmanager_dev_password@postgres:5432/taskmanager?sslmode=disable
# 本番環境（Leapcell）: Leapcellのダッシュボードから取得したURLを設定
DATABASE_URL=postgresql://taskmanager:taskmanager_dev_password@localhost:5432/taskmanager?sslmode=disable

# ====================
# サーバー設定
# ====================

# サーバーポート
PORT=8080

# ベースURL（ローカルストレージ使用時のURL生成に使用）
# 開発環境: http://localhost:8080
# 本番環境: https://your-app.leapcell.dev
BASE_URL=http://localhost:8080

# ====================
# ストレージ設定
# ====================

# ストレージタイプ: local または s3
# 開発環境: local（ローカルファイルシステム）
# 本番環境: s3（Leapcell Object Storage）
STORAGE_TYPE=local

# ローカルストレージ設定（STORAGE_TYPE=local の場合）
UPLOAD_DIR=./uploads

# S3互換ストレージ設定（STORAGE_TYPE=s3 の場合）
# Leapcell Object Storage の設定例：
S3_ENDPOINT=https://objstorage.leapcell.io
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-s3-access-key-id-here
S3_SECRET_KEY=your-s3-secret-access-key-here
S3_CDN_URL=https://your-cdn-url.leapcellobj.com/your-bucket-name

# ====================
# メール送信設定
# ====================

# 開発環境: MailHog（SMTP）を使用
# 本番環境: Resend APIを使用（RESEND_API_KEYが設定されている場合）

# Resend API設定（本番環境用）
# https://resend.com/api-keys で取得
RESEND_API_KEY=

# 送信元メールアドレス
# 開発環境: noreply@taskmanager.local（MailHog用）
# 本番環境: noreply@yourdomain.com（Resendでドメイン認証済みのアドレス）
MAIL_FROM=noreply@taskmanager.local

# SMTPサーバー設定（開発環境: MailHog用）
SMTP_HOST=mailhog
SMTP_PORT=1025

# ====================
# デバッグ設定
# ====================

# デバッグモード（true で詳細ログ出力）
DEBUG=false
